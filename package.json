{
  "name": "instrument-workspace",
  "private": true,
  "packageManager": "pnpm@8.14.0",
  "scripts": {
    "dev": "pnpm --filter workbench dev",
    "build": "pnpm --filter workbench build",
    "build:electron": "pnpm --filter workbench build:electron",
    "build:app": "pnpm --filter workbench build:app",
    "dev:electron": "pnpm --filter workbench dev:electron",
    "repair:electron": "pnpm --filter workbench repair:electron",
    "test": "pnpm --filter workbench test",
    "test:watch": "pnpm --filter workbench test:watch",
    "lint": "pnpm --filter workbench lint",
    "typecheck": "pnpm --filter workbench typecheck",
    "dist": "pnpm --filter workbench dist",
    "dist:dir": "pnpm --filter workbench dist:dir",
    "rebuild:natives": "pnpm --filter workbench rebuild:natives",
    "dev:landing": "pnpm --filter apps-landing-page dev",
    "build:landing": "pnpm --filter apps-landing-page build",
    "preview:landing": "pnpm --filter apps-landing-page preview",
    "deploy:landing": "pnpm --filter apps-landing-page run deploy"
  },
  "pnpm": {
    "overrides": {
      "next": ">=16.2.6",
      "axios": ">=1.15.1",
      "fast-uri": ">=3.1.2",
      "hono": ">=4.12.18",
      "ip-address": ">=10.1.1",
      "esbuild": ">=0.25.0"
    }
  }
}
